#!/usr/bin/env bash

SESSION_NAME="__float_terminal__$(tmux display-message -p '#W')"
CURRENT_PATH="$(tmux display-message -p '#{pane_current_path}')"

if ! tmux has -t "$SESSION_NAME" 2>/dev/null; then
  session_id="$(tmux new-session -c "$CURRENT_PATH" -dP -s "$SESSION_NAME" -F '#{session_id}')"
  tmux set-option -s -t "$session_id" detach-on-destroy on
  SESSION_NAME="$session_id"
fi

tmux popup \
  -w '95%' \
  -h '95%' \
  -b rounded \
  -E \
  "tmux attach-session -t \"$SESSION_NAME\""
