#!/usr/bin/env bash
set -eEo pipefail

DISTROMAC_PATH="${DISTROMAC_PATH:-$HOME/.distromac}"

echo "Updating distromac..."

# Pull latest
cd "$DISTROMAC_PATH"
git pull --rebase

# Run pending migrations
distromac-migrate

# Re-apply current theme (regenerates templates with potentially new templates)
current_theme=$(distromac-theme-current 2>/dev/null || echo "")
if [[ -n $current_theme ]] && [[ $current_theme != "No theme set" ]]; then
  echo "Re-applying theme: $current_theme"
  distromac-theme-set "$current_theme"
fi

# Re-symlink user dotfiles (mirror approach: dirs created, only files symlinked)
USER_DOTFILES="$HOME/.config/distromac/dotfiles"
if [[ -d $USER_DOTFILES ]]; then
  _link_dotfiles() {
    local src_dir="$1" target_dir="$2"
    for src in "$src_dir"/.* "$src_dir"/*; do
      [[ ! -e $src ]] && continue
      local fname
      fname=$(basename "$src")
      [[ $fname == "." || $fname == ".." ]] && continue
      local target="$target_dir/$fname"
      if [[ -d $src ]]; then
        mkdir -p "$target"
        _link_dotfiles "$src" "$target"
      else
        if [[ -L $target ]] && [[ "$(readlink "$target")" == "$src" ]]; then
          continue
        fi
        [[ -e $target ]] && mv "$target" "${target}.distromac-backup.$(date +%s)"
        ln -s "$src" "$target"
        echo "Linked ~/${target#$HOME/}"
      fi
    done
  }
  _link_dotfiles "$USER_DOTFILES" "$HOME"
fi

# Run hook
distromac-hook post-update || true

echo "distromac updated to $(distromac-version)"
